{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Echo AEC",
  "version": "0.1.0",
  "identifier": "com.echoaec.app",
  "build": {
    "beforeDevCommand": "npm --prefix C:/echo-aec/web-ui run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm --prefix C:/echo-aec/web-ui run build",
    "frontendDist": "../web-ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Echo AEC - 回声消除",
        "width": 480,
        "height": 640,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/vbcable"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
